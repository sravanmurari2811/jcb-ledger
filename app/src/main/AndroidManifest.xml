<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.JCBLedger"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".LoginActivity" android:exported="false" />
        <activity android:name=".RegisterActivity" android:exported="false" />
        <activity android:name=".DashboardActivity" android:exported="false" />
        <activity android:name=".WorkEntryActivity" android:exported="false" />
        <activity android:name=".PendingBillsActivity" android:exported="false" />
        <activity android:name=".WorkEntryDetailsActivity" android:exported="false" />
        <activity android:name=".ReportsActivity" android:exported="false" />
        <activity android:name=".CustomerSearchActivity" android:exported="false" />
        <activity android:name=".TransactionHistoryActivity" android:exported="false" />
        <activity android:name=".DriverExpenseActivity" android:exported="false" />
        <activity android:name=".DriverListActivity" android:exported="false" />
        <activity android:name=".AddDriverEntryActivity" android:exported="false" />

    </application>

</manifest>
